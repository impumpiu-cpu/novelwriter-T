{
  "name": "nov-wr-web",
  "private": true,
  "version": "0.0.1-beta.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest",
    "test:run": "vitest run",
    "test:contracts": "vitest run src/__tests__/contracts",
    "test:runtime": "vitest run src/__tests__/runtime",
    "test:orchestration": "vitest run src/__tests__/orchestration",
    "test:components": "vitest run src/__tests__/components",
    "test:pages": "vitest run src/__tests__/pages",
    "test:studio-regression": "vitest run src/__tests__/contracts/world src/__tests__/runtime/world src/__tests__/orchestration/studio src/__tests__/components/world src/__tests__/components/studio src/__tests__/pages/studio",
    "test:e2e": "playwright test",
    "test:e2e:mock": "playwright test --config=playwright.config.ts",
    "test:e2e:integration": "playwright test --config=playwright.integration.config.ts",
    "test:e2e:studio:mock": "playwright test --config=playwright.config.ts e2e/mock/studio",
    "test:e2e:studio:integration": "playwright test --config=playwright.integration.config.ts e2e/integration/studio"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@tanstack/react-query": "^5.90.20",
    "@xyflow/react": "^12.10.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.38.0",
    "lucide-react": "^0.469.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.13.0",
    "tailwind-merge": "^2.6.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@playwright/test": "^1.58.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.2.0",
    "@types/react": "^19.2.10",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.3",
    "autoprefixer": "^10.4.24",
    "eslint": "^9.39.2",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.0",
    "globals": "^17.3.0",
    "jsdom": "^28.0.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.54.0",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  },
  "overrides": {
    "ajv": "6.14.0",
    "flatted": "3.4.2",
    "undici": "7.24.7",
    "rollup": "4.60.1",
    "picomatch@2.3.1": "2.3.2",
    "picomatch@4.0.3": "4.0.4",
    "minimatch@3.1.2": "3.1.5",
    "minimatch@9.0.5": "9.0.9",
    "brace-expansion@1.1.12": "1.1.13",
    "brace-expansion@2.0.2": "2.0.3"
  }
}
