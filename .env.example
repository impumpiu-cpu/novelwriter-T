# Конфигурация LLM для selfhost (OpenAI-совместимый эндпоинт)
OPENAI_API_KEY=your_api_key
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o-mini

# Среда выполнения
# ENVIRONMENT=dev  # dev | prod | production
# VITE_LEGAL_CONTACT_EMAIL=hello@your-domain.com

# Предохранители hosted / ограничители расходов
# HOSTED_MAX_USERS=100
# AI_MANUAL_DISABLE=false
# AI_HARD_STOP_USD=150
# LLM_DEFAULT_INPUT_COST_PER_MILLION_USD=0.0
# LLM_DEFAULT_OUTPUT_COST_PER_MILLION_USD=0.0
# ENABLE_EVENT_TRACKING=false
# ENABLE_DEBUG_ENDPOINTS=false

# Аутентификация hosted
# DEPLOY_MODE=hosted
# HOSTED_INVITE_CODES=[{"code":"writer-a-code","channel":"longkong","invite_batch":"batch-a"},{"code":"writer-b-code","channel":"wechat","invite_batch":"batch-b"}]
# HOSTED_GITHUB_LOGIN_ENABLED=false
# GITHUB_OAUTH_CLIENT_ID=your-github-oauth-client-id
# GITHUB_OAUTH_CLIENT_SECRET=your-github-oauth-client-secret
# GITHUB_OAUTH_REDIRECT_URI=https://your-domain.example/api/auth/github/callback

# Серверная конфигурация LLM для hosted
# Фоновые задачи hosted (bootstrap и т. п.) читают HOSTED_LLM_* при DEPLOY_MODE=hosted.
# HOSTED_LLM_BASE_URL=https://your-gateway.example/v1
# HOSTED_LLM_API_KEY=your-hosted-llm-key
# HOSTED_LLM_MODEL=gpt-4o-mini

# Параметры продолжения по умолчанию
# MAX_CONTEXT_CHAPTERS=5
# DEFAULT_CONTINUATION_TOKENS=4000

# Настройка bootstrap (извлечение мира из глав)
# BOOTSTRAP_LLM_TIMEOUT_SECONDS=120
# BOOTSTRAP_MAX_CANDIDATES=500

# Параллелизм LLM / разделение дорожек
# MAX_CONCURRENT_LLM_CALLS=4
# MAX_BACKGROUND_CONCURRENT_LLM_CALLS=1

# JWT-аутентификация (ОБЯЗАТЕЛЬНО в production)
JWT_SECRET_KEY=replace-with-random-64-char-secret
# JWT_ALGORITHM=HS256
# JWT_EXPIRE_MINUTES=1440

# CORS (JSON-массив)
# CORS_ALLOWED_ORIGINS=["http://localhost:5173"]

# Конфигурация базы данных (SQLite для разработки, PostgreSQL для production)
# DATABASE_URL=sqlite:////abs/path/to/novels.db
# DATABASE_URL=postgresql://scngs:password@localhost:5432/scngs
# SCNGS_DATA_DIR=data
# DB_AUTO_CREATE=false
